local isDraggingWindow = false
local dragInputConnection = nil
local dragStartPosition = nil
local startWindowPosition = nil

local function UpdateWindowDrag(input)
	local delta = input.Position - dragStartPosition
	MainFrame.Position = UDim2.new(
		startWindowPosition.X.Scale,
		startWindowPosition.X.Offset + delta.X,
		startWindowPosition.Y.Scale,
		startWindowPosition.Y.Offset + delta.Y
	)
end

local function StartWindowDrag(input)
	if isDraggingFOV then return end
	isDraggingWindow = true
	dragStartPosition = input.Position
	startWindowPosition = MainFrame.Position
	input.Changed:Connect(function()
		if input.UserInputState == Enum.UserInputState.End then
			isDraggingWindow = false
			dragInputConnection = nil
		end
	end)
end

local function SetDragInput(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInputConnection = input
	end
end

DragArea.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
