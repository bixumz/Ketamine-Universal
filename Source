local FlyBodyVelocity = nil
local FlyBodyGyro = nil
local FlyHeartbeatConnection = nil
local FlySpeed = 50

local function UpdateFlySpeed()
	local speedInput = tonumber(FlySpeedInput.Text)
	if speedInput and speedInput > 0 then
		FlySpeed = speedInput
	else
		FlySpeed = 50
		FlySpeedInput.Text = "50"
	end
end

FlySpeedInput.FocusLost:Connect(UpdateFlySpeed)
FlySpeedInput:GetPropertyChangedSignal("Text"):Connect(UpdateFlySpeed)

function StopFly()
	if FlyHeartbeatConnection then FlyHeartbeatConnection:Disconnect() FlyHeartbeatConnection = nil end
	if FlyBodyVelocity then FlyBodyVelocity:Destroy() FlyBodyVelocity = nil end
	if FlyBodyGyro then FlyBodyGyro:Destroy() FlyBodyGyro = nil end
	if LocalPlayer.Character then
		local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			humanoid.AutoRotate = true
			humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
		end
	end
end

function StartFly()
	if not LocalPlayer.Character then return end
	StopFly()
	local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart") or 
	                 LocalPlayer.Character:FindFirstChild("Torso") or 
	                 LocalPlayer.Character:FindFirstChild("UpperTorso")
	if not rootPart then return end
	local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	humanoid.AutoRotate = false

	FlyBodyGyro = Instance.new("BodyGyro")
	FlyBodyGyro.P = 9e4
	FlyBodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
	FlyBodyGyro.CFrame = rootPart.CFrame
	FlyBodyGyro.Parent = rootPart

	FlyBodyVelocity = Instance.new("BodyVelocity")
	FlyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
	FlyBodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
	FlyBodyVelocity.Parent = rootPart

	FlyHeartbeatConnection = RunService.Heartbeat:Connect(function()
		if not ToggleStates.Fly or not LocalPlayer.Character or not humanoid or humanoid.Health <= 0 then
			StopFly()
			return
		end
		local moveDirection = Vector3.new()
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then
			moveDirection = moveDirection + Camera.CFrame.LookVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then
			moveDirection = moveDirection - Camera.CFrame.LookVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then
			moveDirection = moveDirection - Camera.CFrame.RightVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then
			moveDirection = moveDirection + Camera.CFrame.RightVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
			moveDirection = moveDirection + Vector3.new(0, 1, 0)
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
			moveDirection = moveDirection - Vector3.new(0, 1, 0)
		end
		if moveDirection.Magnitude > 0 then
			FlyBodyVelocity.Velocity = moveDirection.Unit * FlySpeed
		else
			FlyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
		end
		FlyBodyGyro.CFrame = Camera.CFrame
	end)
end

local VehicleFlyActive = false
local VehicleFlySpeed = 90
local VehicleFlyKeyDownConnection = nil
local VehicleFlyKeyUpConnection = nil
local VehicleControlState = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
local VehicleBodyGyro = nil
local VehicleBodyVelocity = nil

local function GetVehicleSeat(character)
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil end
    local seat = humanoid.SeatPart
    if seat and seat:IsA("VehicleSeat") then
        return seat
    end
    return nil
end

local function StopVehicleFly()
    VehicleFlyActive = false
    if VehicleFlyKeyDownConnection then VehicleFlyKeyDownConnection:Disconnect() VehicleFlyKeyDownConnection = nil end
    if VehicleFlyKeyUpConnection then VehicleFlyKeyUpConnection:Disconnect() VehicleFlyKeyUpConnection = nil end
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid.PlatformStand = false end
    end
    pcall(function() Workspace.CurrentCamera.CameraType = Enum.CameraType.Custom end)
    if VehicleBodyGyro then VehicleBodyGyro:Destroy() VehicleBodyGyro = nil end
    if VehicleBodyVelocity then VehicleBodyVelocity:Destroy() VehicleBodyVelocity = nil end
end

local function UpdateVehicleFlySpeed()
    local speedInput = tonumber(VehicleFlySpeedInput.Text)
    if speedInput and speedInput > 0 then
        VehicleFlySpeed = speedInput
    else
        VehicleFlySpeed = 90
        VehicleFlySpeedInput.Text = "90"
    end
end

local function StartVehicleFly()
    local character = LocalPlayer.Character
    if not character then return end
    local vehicleSeat = GetVehicleSeat(character)
    if not vehicleSeat then 
        ToggleStates.VehicleFly = false
        AnimateToggleFill(VehicleFlyToggleFill, false)
        return 
    end

    if VehicleFlyActive then StopVehicleFly() end

    local camera = Workspace.CurrentCamera
    camera.CameraType = Enum.CameraType.Track

    VehicleControlState = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}

    VehicleBodyGyro = Instance.new("BodyGyro")
    VehicleBodyGyro.P = 9e4
    VehicleBodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    VehicleBodyGyro.CFrame = vehicleSeat.CFrame
    VehicleBodyGyro.Parent = vehicleSeat

    VehicleBodyVelocity = Instance.new("BodyVelocity")
    VehicleBodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    VehicleBodyVelocity.Velocity = Vector3.new(0, 0, 0)
    VehicleBodyVelocity.Parent = vehicleSeat

    VehicleFlyActive = true

    VehicleFlyKeyDownConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.W then VehicleControlState.F = 1
        elseif input.KeyCode == Enum.KeyCode.S then VehicleControlState.B = -1
        elseif input.KeyCode == Enum.KeyCode.A then VehicleControlState.L = -1
        elseif input.KeyCode == Enum.KeyCode.D then VehicleControlState.R = 1
        elseif input.KeyCode == Enum.KeyCode.E then VehicleControlState.E = 1
        elseif input.KeyCode == Enum.KeyCode.Q then VehicleControlState.Q = -1
        end
    end)

    VehicleFlyKeyUpConnection = UserInputService.InputEnded:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.W then VehicleControlState.F = 0
        elseif input.KeyCode == Enum.KeyCode.S then VehicleControlState.B = 0
        elseif input.KeyCode == Enum.KeyCode.A then VehicleControlState.L = 0
        elseif input.KeyCode == Enum.KeyCode.D then VehicleControlState.R = 0
        elseif input.KeyCode == Enum.KeyCode.E then VehicleControlState.E = 0
        elseif input.KeyCode == Enum.KeyCode.Q then VehicleControlState.Q = 0
        end
    end)

    task.spawn(function()
        repeat task.wait() until not VehicleFlyActive
        StopVehicleFly()
    end)
    
    task.spawn(function()
        repeat
            task.wait()
            if not VehicleFlyActive or not vehicleSeat or not vehicleSeat.Parent then break end
            camera = Workspace.CurrentCamera
            VehicleBodyGyro.CFrame = camera.CFrame
            local forwardDirection = camera.CFrame.LookVector * (VehicleControlState.F + VehicleControlState.B)
            local offsetDirection = (camera.CFrame * CFrame.new(VehicleControlState.L + VehicleControlState.R, (VehicleControlState.F + VehicleControlState.B + VehicleControlState.Q + VehicleControlState.E) * 0.2, 0)).Position - camera.CFrame.Position
            VehicleBodyVelocity.Velocity = (forwardDirection + offsetDirection) * VehicleFlySpeed
        until not VehicleFlyActive
    end)
end

VehicleFlySpeedInput.FocusLost:Connect(UpdateVehicleFlySpeed)
VehicleFlySpeedInput:GetPropertyChangedSignal("Text"):Connect(UpdateVehicleFlySpeed)

local InfiniteJumpConnection = nil
function EnableInfiniteJump()
	if InfiniteJumpConnection then InfiniteJumpConnection:Disconnect() end
	InfiniteJumpConnection = UserInputService.JumpRequest:Connect(function()
		if LocalPlayer.Character then
			local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
			if humanoid then
				humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
			end
		end
	end)
end
function DisableInfiniteJump()
	if InfiniteJumpConnection then
		InfiniteJumpConnection:Disconnect()
		InfiniteJumpConnection = nil
	end
end

local NoClipConnection = nil
function EnableNoClip()
	if NoClipConnection then NoClipConnection:Disconnect() end
	NoClipConnection = RunService.Stepped:Connect(function()
		if ToggleStates.NoClip and LocalPlayer.Character then
			for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CanCollide = false
				end
			end
		end
	end)
end
function DisableNoClip()
	if NoClipConnection then
		NoClipConnection:Disconnect()
		NoClipConnection = nil
	end
	if LocalPlayer.Character then
		for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = true
			end
		end
	end
end

local ActiveHighlights = {}

local function GetTeamColor(player)
    if not player.Team then return Color3.fromRGB(45, 116, 207) end
    
    local teamName = player.Team.Name
    
    if teamName == "Inmates" or teamName == "Prisoners" then
        return Color3.fromRGB(255, 140, 0)
    elseif teamName == "Criminals" then
        return Color3.fromRGB(255, 0, 0)
    elseif teamName == "Guards" or teamName == "Police" then
        return Color3.fromRGB(0, 120, 255)
    else
        return Color3.fromRGB(45, 116, 207)
    end
end

local function ClearPlayerHighlight(player)
    if ActiveHighlights[player] then
        local data = ActiveHighlights[player]
        
        if data.highlight and data.highlight.Parent then
            data.highlight:Destroy()
        end
        
        if data.connections then
            for _, connection in ipairs(data.connections) do
                if connection and connection.Connected then
                    connection:Disconnect()
                end
            end
        end
        
        ActiveHighlights[player] = nil
    end
end

local function ClearAllHighlights()
    for player in pairs(ActiveHighlights) do
        ClearPlayerHighlight(player)
    end
    ActiveHighlights = {}
end

local function AddPlayerHighlight(player)
    if not player or player == LocalPlayer then return end
    
    ClearPlayerHighlight(player)
    
    local data = { connections = {} }
    ActiveHighlights[player] = data
    
    local function AttachHighlight(character)
        if not character then return end
        if not (ToggleStates.UniversalESP or ToggleStates.TeamESP or ToggleStates.PlayerESP) then return end
        
        local shouldHighlight = false
        if ToggleStates.UniversalESP then
            shouldHighlight = true
        elseif ToggleStates.TeamESP and ESPConfig.TargetTeam ~= "" and player.Team and player.Team.Name == ESPConfig.TargetTeam then
            shouldHighlight = true
        elseif ToggleStates.PlayerESP and PlayerESPFilter ~= "" then
            if string.lower(player.Name) == string.lower(PlayerESPFilter) or 
               (player.DisplayName and string.lower(player.DisplayName) == string.lower(PlayerESPFilter)) then
                shouldHighlight = true
            end
        end
        
        if not shouldHighlight then return end
        
        if data.highlight and data.highlight.Parent then
            data.highlight:Destroy()
            data.highlight = nil
        end
        
        local highlight = Instance.new("Highlight")
        highlight.Name = "PlayerHighlight"
        highlight.Adornee = character
        highlight.FillColor = GetTeamColor(player)
        highlight.FillTransparency = 0.25
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = character
        
        data.highlight = highlight
    end
    
    if player.Character then
        AttachHighlight(player.Character)
    end
    
    table.insert(data.connections, player.CharacterAdded:Connect(function(character)
        task.wait(0.1)
        AttachHighlight(character)
    end))
    
    table.insert(data.connections, player:GetPropertyChangedSignal("Team"):Connect(function()
        if data.highlight and data.highlight.Parent then
            data.highlight.FillColor = GetTeamColor(player)
        end
    end))
    
    table.insert(data.connections, player.CharacterRemoving:Connect(function()
        if data.highlight and data.highlight.Parent then
            data.highlight:Destroy()
            data.highlight = nil
        end
    end))
end

local function RefreshAllHighlights()
    ClearAllHighlights()
    
    if not (ToggleStates.UniversalESP or ToggleStates.TeamESP or ToggleStates.PlayerESP) then return end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            AddPlayerHighlight(player)
        end
    end
end

Players.PlayerAdded:Connect(function(player)
    task.wait(0.5)
    if ToggleStates.UniversalESP or ToggleStates.TeamESP or ToggleStates.PlayerESP then
        AddPlayerHighlight(player)
    end
end)

Players.PlayerRemoving:Connect(function(player)
    ClearPlayerHighlight(player)
end)

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        local data = { connections = {} }
        ActiveHighlights[player] = data
        
        table.insert(data.connections, player.CharacterAdded:Connect(function(character)
            task.wait(0.1)
            if ToggleStates.UniversalESP or ToggleStates.TeamESP or ToggleStates.PlayerESP then
                ClearPlayerHighlight(player)
                AddPlayerHighlight(player)
            end
        end))
        
        table.insert(data.connections, player.CharacterRemoving:Connect(function()
            if data.highlight and data.highlight.Parent then
                data.highlight:Destroy()
                data.highlight = nil
            end
        end))
        
        table.insert(data.connections, player:GetPropertyChangedSignal("Team"):Connect(function()
            if data.highlight and data.highlight.Parent then
                data.highlight.FillColor = GetTeamColor(player)
            end
        end))
    end
end

local ActiveTracers = {}

local function ClearAllTracers()
    for player, line in pairs(ActiveTracers) do
        if line then
            line:Destroy()
        end
    end
    ActiveTracers = {}
end

local function UpdateTracers()
	if not ToggleStates.Tracer then
		for player, line in pairs(ActiveTracers) do
			if line then line.Visible = false end
		end
		return
	end

	local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
	for _, player in ipairs(Players:GetPlayers()) do
		if player == LocalPlayer then continue end
		if player.Character and player.Character:FindFirstChild("Head") then
			local head = player.Character.Head
			local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
			if onScreen then
				if not ActiveTracers[player] then
					local line = Drawing.new("Line")
					line.Thickness = 2.2
					line.Color = Color3.fromRGB(247, 25, 36)
					line.Transparency = 0.6
					ActiveTracers[player] = line
				end
				local line = ActiveTracers[player]
				line.From = screenCenter
				line.To = Vector2.new(screenPos.X, screenPos.Y)
				line.Visible = true
			else
				if ActiveTracers[player] then
					ActiveTracers[player].Visible = false
				end
			end
		else
			if ActiveTracers[player] then
				ActiveTracers[player].Visible = false
			end
		end
	end

	for player in pairs(ActiveTracers) do
		if not Players:FindFirstChild(player.Name) then
			ActiveTracers[player]:Destroy()
			ActiveTracers[player] = nil
		end
	end
end

local function AnimateToggleFill(fillFrame, isOn)
	if isOn then
		fillFrame:TweenSize(UDim2.new(0, 10, 0, 10), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
	else
		fillFrame:TweenSize(UDim2.new(0, 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
	end
end

