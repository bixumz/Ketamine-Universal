	local absoluteSize = FOVSliderBar.AbsoluteSize
	local relativeX = math.clamp(mousePosition.X - absolutePosition.X, 0, absoluteSize.X)
	local newFOV = math.floor(50 + (relativeX / absoluteSize.X) * 250)
	AimbotConfig.FOVRadius = newFOV
	FOVValueDisplay.Text = tostring(newFOV)
	FOVSliderKnob.Position = UDim2.new((newFOV-50)/250, -6, -2, 0)
end

