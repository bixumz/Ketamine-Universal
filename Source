local MaxTargetDistance = 1000

local function GetTargetPart(character, preferredPart)
    if not character then return nil end
    
    if preferredPart == "Head" then
        return character:FindFirstChild("Head") 
            or character:FindFirstChild("HumanoidRootPart")
            or character:FindFirstChild("Torso") 
            or character:FindFirstChild("UpperTorso")
    elseif preferredPart == "Torso" then
        return character:FindFirstChild("HumanoidRootPart")
            or character:FindFirstChild("Torso")
            or character:FindFirstChild("UpperTorso")
            or character:FindFirstChild("LowerTorso")
            or character:FindFirstChild("Head")
    elseif preferredPart == "Legs" then
        return character:FindFirstChild("Left Leg")
            or character:FindFirstChild("Right Leg")
            or character:FindFirstChild("LeftLowerLeg")
            or character:FindFirstChild("RightLowerLeg")
            or character:FindFirstChild("LeftUpperLeg")
            or character:FindFirstChild("RightUpperLeg")
            or character:FindFirstChild("HumanoidRootPart")
            or character:FindFirstChild("Head")
    else
        return character:FindFirstChild("Head")
            or character:FindFirstChild("HumanoidRootPart")
            or character:FindFirstChild("Torso")
            or character:FindFirstChild("UpperTorso")
    end
end

local function IsValidTarget(player, teamFilter)
    if not player or player == LocalPlayer then return false end
    if not player.Character then return false end
    
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    
    if teamFilter ~= nil then
        if type(teamFilter) == "string" and teamFilter ~= "" then
            if not player.Team or player.Team.Name ~= teamFilter then
                return false
            end
        end
    else
        if not ToggleStates.TeamAimbot and player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team then
            return false
        end
    end
    
    return true
end

local function IsTargetVisible(targetPart)
    if not LocalPlayer.Character or not targetPart then return false end
    
    local camera = workspace.CurrentCamera
    local origin = camera.CFrame.Position
    local target = targetPart.Position
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, camera}
    raycastParams.IgnoreWater = true
    
    local raycastResult = workspace:Raycast(origin, (target - origin), raycastParams)
    
    if not raycastResult then
        return true
    end
    
    local hitInstance = raycastResult.Instance
    if hitInstance then
        local targetCharacter = targetPart.Parent
        if targetCharacter and (hitInstance:IsDescendantOf(targetCharacter) or hitInstance == targetCharacter) then
            return true
        end
    end
    
    return false
end

local function GetClosestTarget(teamFilter, useFOV)
    if not LocalPlayer.Character then return nil end
    
    local myRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart") 
        or LocalPlayer.Character:FindFirstChild("Torso")
        or LocalPlayer.Character:FindFirstChild("UpperTorso")
    
    if not myRoot then return nil end
    
    local mousePos = useFOV and UserInputService:GetMouseLocation() or nil
    local closestTarget = nil
    local closestDistance = math.huge
    local closestScreenDistance = math.huge
    
    for _, player in ipairs(Players:GetPlayers()) do
        if IsValidTarget(player, teamFilter) then
            local part = GetTargetPart(player.Character, AimbotConfig.TargetPart)
            if part then
                local worldDistance = (part.Position - myRoot.Position).Magnitude
                if worldDistance <= MaxTargetDistance then
                    if IsTargetVisible(part) then
                        if useFOV then
                            local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                            if onScreen then
                                local targetPos = Vector2.new(screenPos.X, screenPos.Y)
                                local screenDistance = (targetPos - mousePos).Magnitude
                                
                                if screenDistance <= AimbotConfig.FOVRadius and screenDistance < closestScreenDistance then
                                    closestScreenDistance = screenDistance
                                    closestTarget = part
                                end
                            end
                        else
                            if worldDistance < closestDistance then
                                closestDistance = worldDistance
                                closestTarget = part
                            end
                        end
                    end
                end
            end
        end
    end
    
    return closestTarget
end

RunService.Heartbeat:Connect(function()
    if not Camera then 
        Camera = workspace.CurrentCamera 
        return
    end

    if FOVCircleDisplay then
        FOVCircleDisplay.Visible = ToggleStates.SilentAim
        if FOVCircleDisplay.Visible then
            local mousePos = UserInputService:GetMouseLocation()
            local radius = AimbotConfig.FOVRadius
            FOVCircleDisplay.Position = UDim2.new(0, mousePos.X - radius, -0.055, mousePos.Y - radius)
            FOVCircleDisplay.Size = UDim2.new(0, radius * 2, 0, radius * 2)
        end
    end

    if ToggleStates.Aimbot then
        local target = GetClosestTarget(nil, false)
        if target then
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, target.Position)
        end
    end

    if ToggleStates.SilentAim and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local target = GetClosestTarget(nil, true)
        if target then
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, target.Position)
        end
    end

    if ToggleStates.TeamAimbot and AimbotConfig.TargetTeam ~= "" then
        local target = GetClosestTarget(AimbotConfig.TargetTeam, false)
        if target then
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, target.Position)
        end
    end

    UpdateTracers()
end)

